<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YourTVSat - Scanner Pro</title>
    <style>
        body { background-color: #000; color: #d4af37; font-family: sans-serif; text-align: center; padding: 20px; }
        .container { max-width: 500px; margin: auto; border: 1px solid #d4af37; padding: 20px; border-radius: 15px; background: #111; }
        input { width: 90%; padding: 10px; margin: 10px 0; background: #222; border: 1px solid #444; color: #fff; border-radius: 5px; }
        button { background: #d4af37; color: #000; border: none; padding: 15px 30px; font-weight: bold; cursor: pointer; border-radius: 5px; width: 100%; }
        #results { margin-top: 20px; font-weight: bold; }
        .success { color: #00ff00; }
        .error { color: #ff0000; }
    </style>
</head>
<body>

    <div class="container">
        <h1 style="color: #d4af37;">ATLAS PRO OFFICIEL</h1>
        <p>Scanner de Test YourTVSat</p>
        
        <input type="text" id="host" placeholder="URL Serveur (ex: http://moniptv.com)">
        <input type="text" id="port" placeholder="Port (ex: 8080)">
        <input type="text" id="user" placeholder="Username">
        <input type="text" id="pass" placeholder="Password">
        
        <button onclick="lancerTest()">VÉRIFIER L'ABONNEMENT</button>

        <div id="results">En attente...</div>
    </div>

    <script>
        async function lancerTest() {
            const resDiv = document.getElementById('results');
            const host = document.getElementById('host').value;
            const port = document.getElementById('port').value;
            const user = document.getElementById('user').value;
            const pass = document.getElementById('pass').value;

            if(!host || !user || !pass) {
                alert("Remplis tous les champs !");
                return;
            }

            resDiv.innerHTML = "Connexion en cours...";

            // On utilise ton propre serveur comme Proxy pour éviter les blocages
            const urlTest = `/api/proxy?host=${encodeURIComponent(host)}&port=${port}&user=${user}&pass=${pass}`;

            try {
                const response = await fetch(urlTest);
                const data = await response.json();

                if(data.auth === 1) {
                    resDiv.innerHTML = `<span class="success">✅ VALIDE ! <br> Expire le : ${data.expiry}</span>`;
                } else {
                    resDiv.innerHTML = `<span class="error">❌ Identifiants Incorrects</span>`;
                }
            } catch (err) {
                resDiv.innerHTML = `<span class="error">⚠️ Erreur : Serveur injoignable</span>`;
            }
        }
    </script>
</body>
</html>
